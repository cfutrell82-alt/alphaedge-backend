{
  "name": "alphaedge-backend",
  "version": "1.0.0",
  "description": "AlphaEdge backend — auth, payments, and signal delivery",
  "main": "alphaedge-auth.js",
  "scripts": {
    "start:auth":    "node alphaedge-auth.js",
    "start:stripe":  "node alphaedge-stripe-server.js",
    "start:signals": "node alphaedge-signals.js",
    "dev:auth":      "nodemon alphaedge-auth.js",
    "dev:stripe":    "nodemon alphaedge-stripe-server.js",
    "dev:signals":   "nodemon alphaedge-signals.js"
  },
  "dependencies": {
    "express":                  "^4.18.2",
    "stripe":                   "^14.21.0",
    "bcryptjs":                 "^2.4.3",
    "jsonwebtoken":             "^9.0.2",
    "nodemailer":               "^6.9.9",
    "cors":                     "^2.8.5",
    "dotenv":                   "^16.4.4",
    "helmet":                   "^7.1.0",
    "express-rate-limit":       "^7.2.0",
    "express-slow-down":        "^2.0.1",
    "node-telegram-bot-api":    "^0.64.0",
    "axios":                    "^1.6.7",
    "node-cron":                "^3.0.3",
    "uuid":                     "^9.0.1",
    "winston":                  "^3.11.0",
    "@prisma/client":           "^5.10.2",
    "crypto":                   "^1.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "prisma":  "^5.10.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}